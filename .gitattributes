# Normalize all text files to LF in the repository
* text=auto eol=lf

# Java / Spring Boot
*.java    text eol=lf
*.xml     text eol=lf
*.properties text eol=lf
*.yml     text eol=lf
*.yaml    text eol=lf

# Web / Angular
*.ts      text eol=lf
*.html    text eol=lf
*.css     text eol=lf
*.scss    text eol=lf
*.json    text eol=lf

# SQL
*.sql     text eol=lf

# Scripts
*.ps1     text eol=lf
*.sh      text eol=lf
*.bat     text eol=lf

# Documentation
*.md      text eol=lf

# Binary — no line ending conversion
*.pdf     binary
*.png     binary
*.jpg     binary
*.ico     binary
*.jar     binary
*.apk     binary
*.aab     binary
